<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingLeft="12dp"
    android:paddingRight="12dp"
    android:paddingTop="8dp"
    android:paddingBottom="8dp">

    <!-- header -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="VoiceLedger"
        android:textColor="#1A1E2B"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <!-- summary row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- Today -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/notif_badge_bg"
            android:padding="8dp">

            <TextView
                android:id="@+id/notif_today_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="今日"
                android:textColor="#5C6378"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/notif_today_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥0.00"
                android:textColor="#1A1E2B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/notif_today_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0笔"
                android:textColor="#5C6378"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Monthly -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:background="@drawable/notif_badge_bg"
            android:padding="8dp"
            android:layout_marginLeft="16dp">

            <TextView
                android:id="@+id/notif_month_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="本月"
                android:textColor="#5C6378"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/notif_monthly_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="¥0.00"
                android:textColor="#1EA58B"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp" />

            <TextView
                android:id="@+id/notif_monthly_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0笔"
                android:textColor="#5C6378"
                android:textSize="12sp" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>